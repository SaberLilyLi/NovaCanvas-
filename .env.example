DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=sk-Ee0oVbTSiE9a8x6r0oxICmt5l5AEHz10Lf2wNYRZjgfKMLIT
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_BASE_URL=https://www.packyapi.coms/v1
# Cap output resolution when the relay only supports 1K: 1k | 2k | 4k
OPENAI_IMAGE_MAX_RESOLUTION=1k
DOUBAO_API_KEY=ark-05cc115c-7667-423d-a1ba-d8ec51bb39ac-1596b
ARK_API_KEY=ark-05cc115c-7667-423d-a1ba-d8ec51bb39ac-1596b
